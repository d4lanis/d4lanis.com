# Appwrite Configuration
# Sign up at https://cloud.appwrite.io/ to get these values
# Create a project, database, and collection for contact form submissions

# Your Appwrite API endpoint (default: https://cloud.appwrite.io/v1)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID
VITE_APPWRITE_PROJECT_ID=your_project_id_here

# Your Appwrite Database ID
VITE_APPWRITE_DATABASE_ID=your_database_id_here

# Your Appwrite Collection ID (for contact form submissions)
VITE_APPWRITE_COLLECTION_ID=your_collection_id_here
